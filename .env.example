# Django settings
DEBUG=True
SECRET_KEY=django-insecure-replace-this-with-a-real-key-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (for Django database URL format)
# postgres://user:password@host:port/dbname
DATABASE_URL=postgres://aura_user:aura_password@db:5432/aura_db

# PostgreSQL service configuration (used by db service in docker-compose.yml)
POSTGRES_DB=aura_db
POSTGRES_USER=aura_user
POSTGRES_PASSWORD=aura_password
POSTGRES_HOST=db
POSTGRES_PORT=5432
